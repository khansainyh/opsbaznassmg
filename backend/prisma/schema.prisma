generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          Role           @default(Super_Admin)
  created_at    DateTime       @default(now())
  notifications Notification[]
}

model Mustahik {
  id              String     @id @default(uuid())
  nrm             String?    @unique
  nama            String
  nik             String     @unique
  tempat_lahir    String
  tanggal_lahir   String
  jenis_kelamin   String
  pekerjaan       String?
  alamat          String     @db.Text
  handphone       String
  email           String?
  catatan         String?    @db.Text

  status_graduasi String     @default("Belum")
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  proposals       Proposal[]
}

model Upz {
  id         String      @id @default(uuid())
  kategori   KategoriUPZ
  nama_upz   String
  alamat     String?
  metadata   Json?
  created_at DateTime    @default(now())
}

model Pilar {
  code     String    @id
  name     String
  category String?
  status   String?   @default("Aktif")
  programs Program[]
}

model Program {
  code       String     @id
  pilar_code String
  name       String
  budget_rkat Int?      @default(0)
  rkat_details Json?
  tipe       String     @default("Konsumtif")
  pilar      Pilar      @relation(fields: [pilar_code], references: [code])
  proposals  Proposal[]

  @@index([pilar_code], map: "Program_pilar_code_fkey")
}

model Proposal {
  id                  String    @id @default(uuid())
  agenda_no           Int       @unique @default(autoincrement())
  tanggal_masuk       DateTime
  nama_instansi       String?
  pimpinan_organisasi String?
  nama_pemohon        String
  nama_anak           String?
  nik                 String?
  tempat_lahir        String?
  tanggal_lahir       String?
  jenis_kelamin       String?
  alamat              String?   @db.Text
  kelurahan           String?
  kecamatan           String?
  pekerjaan           String?
  jenis_permohonan    String?
  no_telpon           String?
  email               String?
  jam_pengajuan       String?
  yang_mengajukan     String?
  has_memo            Boolean   @default(false)
  memo_source         String?
  jenis_pengajuan     String    @default("")
  rekomendasi         String?
  keterangan          String?
  status              String    @default("Pending")
  file_gdrive_id      String?
  file_gdrive_link    String?
  mustahik_id         String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  isBeingSurveyed     Boolean?  @default(false)
  score               Int?
  surveyorName        String?
  urgencyLevel        String?
  survey_data         Json?
  surveySubmittedAt   DateTime?
  catatanKepala       String?   @db.Text
  catatanPimpinan     String?   @db.Text
  nominal             Int?
  tipe_bantuan        String?
  alasan_perubahan_nominal String? @db.Text
  asnaf               String?
  rekomendasi_kabag   String?
  hasil_identifikasi  String?   @db.Text
  approval_kabag      Boolean?
  rkat_activity_id    String?
  program             Program?  @relation(fields: [jenis_permohonan], references: [code])
  mustahik            Mustahik? @relation(fields: [mustahik_id], references: [id])

  @@index([jenis_permohonan], map: "Proposal_jenis_permohonan_fkey")
  @@index([mustahik_id], map: "Proposal_mustahik_id_fkey")
}

model Surat {
  id                  String   @id @default(uuid())
  agenda_no           Int      @unique @default(autoincrement())
  tanggal_masuk       DateTime
  nama_instansi       String?
  pimpinan_organisasi String?
  alamat              String?  @db.Text
  kelurahan           String?
  kecamatan           String?
  kategori            String?  // Undangan, Surat Izin Kerja, dll
  keperluan           String   @db.Text
  tanggal_acara       DateTime?
  jam_acara           String?
  no_telpon           String?
  jam_pengajuan       String?
  yang_mengajukan     String?
  arsip               String?
  status              String   @default("Registrasi")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  file_gdrive_id      String?
  file_gdrive_link    String?
  catatanKepala       String?  @db.Text
  catatanPimpinan     String?  @db.Text
  assigned_staff      Json?    // Array of User IDs assigned to attend the event
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  Super_Admin
  Ketua
  Wakil_Ketua_I
  Wakil_Ketua_II
  Wakil_Ketua_III
  Wakil_Ketua_IV
  Kabag_Administrasi
  Kabag_Pelaporan
  Kabag_Pengumpulan
  Kabag_Pendistribusian
  Kabag_Pendayagunaan
  Kepala_Pelaksana
  Staf_Administrasi
  Staf_Distribusi
  Staf_Keuangan
  Staf_Pengumpulan
  Staf_Pelaporan
  Relawan
  Relawan_Sementara
  Tim_Monev
}

enum KategoriUPZ {
  Masjid
  Yayasan_Lembaga
  Sekolah
  OPD
}

model SystemParameter {
  key         String   @id
  value       String   @db.Text
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
}

model ChartOfAccounts {
  coa_code    String    @id @db.VarChar(20)
  nama_akun   String    @db.VarChar(255)
  klasifikasi String?   @db.VarChar(50) // 'Aktiva', 'Kewajiban', 'Saldo', 'Penerimaan', 'Penyaluran'
  tipe_dana   String?   @db.VarChar(30) // 'ZAKAT', 'INFAK_TERIKAT', 'INFAK_TIDAK_TERIKAT', 'AMIL', 'APBD'

  bankAccounts BankAccount[]
  debitRules   CoaMappingRule[] @relation("DebitCoa")
  kreditRules  CoaMappingRule[] @relation("KreditCoa")
  journalEntries JournalEntry[]
}

model BankAccount {
  account_id    String    @id @default(uuid())
  nama_akun     String    @db.VarChar(100) // Contoh: 'BSI - Rekening Utama Zakat', 'Kas Utama Tunai (A) - Zakat'
  tipe_kas      String    @db.VarChar(20)  // 'TUNAI' atau 'BANK'
  kelompok_dana String    @db.VarChar(20)  // 'ZAKAT', 'INFAK_TERIKAT', 'INFAK_TIDAK_TERIKAT', 'AMIL', 'APBD', 'NON-HALAL'
  saldo         Decimal   @db.Decimal(15, 2) @default(0.00)
  no_rekening   String?   @db.VarChar(50)
  kode_laci     String?   @db.VarChar(1)   // 'A' s.d 'G' untuk tipe TUNAI
  coa_code      String    @db.VarChar(20)
  
  coa           ChartOfAccounts @relation(fields: [coa_code], references: [coa_code])
  journalEntries JournalEntry[]
  sourceMutations CashMutation[]
  targetMutationDetails CashMutationDetail[]
}

model CoaMappingRule {
  rule_id         String    @id @default(uuid())
  program_code    String    @db.VarChar(50) // references Program.code
  asnaf_id        String?   @db.VarChar(50) // can be NULL
  tipe_kas        String    @db.VarChar(20)  // 'TUNAI' or 'BANK'
  sumber_dana_tag String    @db.VarChar(20)  // 'ZAKAT', 'IST', 'ISTT', 'AMIL', 'APBD'
  debit_coa_code  String    @db.VarChar(20)
  kredit_coa_code String    @db.VarChar(20)

  debitCoa        ChartOfAccounts @relation("DebitCoa", fields: [debit_coa_code], references: [coa_code])
  kreditCoa       ChartOfAccounts @relation("KreditCoa", fields: [kredit_coa_code], references: [coa_code])
}

model Realisasi {
  transaksi_id String    @id @default(uuid())
  proposal_id  String?   @db.VarChar(191) // references Proposal.id
  rkat_id      String?   @db.VarChar(100) // References target/asnaf id or Program.code
  tanggal      DateTime  @default(now())
  keterangan   String?   @db.Text
  nrm          String?   @db.VarChar(100)
  createdAt    DateTime  @default(now())

  journalEntries JournalEntry[]
}

model JournalEntry {
  entry_id     String    @id @default(uuid())
  transaksi_id String    @db.VarChar(191)
  coa_code     String    @db.VarChar(20)
  debit        Decimal   @db.Decimal(15, 2) @default(0.00)
  kredit       Decimal   @db.Decimal(15, 2) @default(0.00)
  account_id   String?   @db.VarChar(191)

  realisasi    Realisasi       @relation(fields: [transaksi_id], references: [transaksi_id], onDelete: Cascade)
  coa          ChartOfAccounts @relation(fields: [coa_code], references: [coa_code])
  account      BankAccount?    @relation(fields: [account_id], references: [account_id])
}

model CashMutation {
  mutation_id       String    @id @default(uuid())
  source_account_id String    @db.VarChar(191)
  nominal_total     Decimal   @db.Decimal(15, 2)
  tanggal           DateTime  @default(now())
  keterangan        String?   @db.Text

  sourceAccount     BankAccount @relation(fields: [source_account_id], references: [account_id])
  details           CashMutationDetail[]
}

model CashMutationDetail {
  detail_id         String    @id @default(uuid())
  mutation_id       String    @db.VarChar(191)
  target_account_id String    @db.VarChar(191)
  nominal_alokasi   Decimal   @db.Decimal(15, 2)

  mutation          CashMutation @relation(fields: [mutation_id], references: [mutation_id], onDelete: Cascade)
  targetAccount     BankAccount  @relation(fields: [target_account_id], references: [account_id])
}

