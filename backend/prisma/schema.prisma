generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password_hash String
  role          Role           @default(Super_Admin)
  created_at    DateTime       @default(now())
  notifications Notification[]
}

model Mustahik {
  id              String     @id @default(uuid())
  nrm             String?    @unique
  nama            String
  nik             String?    @unique
  tempat_lahir    String?
  tanggal_lahir   String?
  jenis_kelamin   String?
  pekerjaan       String?
  alamat          String?    @db.Text
  handphone       String?
  email           String?
  catatan         String?    @db.Text
  status_graduasi String     @default("Belum")
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  jenis_lembaga   String?
  jumlah_anggota  Int?       @default(0)
  kabupaten       String?
  kategori        String     @default("Perorangan")
  kecamatan       String?
  kelurahan       String?
  nama_pimpinan   String?
  provinsi        String?
  telepon         String?
  proposals       Proposal[]
}

model Muzakki {
  id                 String          @id @default(uuid())
  kategori           String          @default("Perorangan")
  nama               String
  npwp               String?
  zakat_per_bulan    Decimal?        @db.Decimal(15, 2)
  keterangan         String?         @db.Text
  alamat             String          @db.Text
  telepon            String?
  email              String?
  status             String          @default("Aktif")
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  nik                String?         @unique
  tempat_lahir       String?
  tanggal_lahir      String?
  jenis_kelamin      String?
  pekerjaan          String?
  upz                String?
  alamat_kantor      String?         @db.Text
  handphone          String?
  no_pengukuhan      String?
  tanggal_pengukuhan String?
  website            String?
  jenis_lembaga      String?
  fax                String?
  cp_nama            String?
  cp_telepon         String?
  cp_email           String?
  npwz               String?         @unique
  no_rekening        String?         @unique
  penerimaans        PenerimaanZis[]
}

model Upz {
  id         String      @id @default(uuid())
  kategori   KategoriUPZ
  nama_upz   String
  alamat     String?
  metadata   Json?
  created_at DateTime    @default(now())
}

model Pilar {
  code     String    @id
  name     String
  category String?
  status   String?   @default("Aktif")
  programs Program[]
}

model Program {
  code         String     @id
  pilar_code   String
  name         String
  budget_rkat  Int?       @default(0)
  rkat_details Json?
  tipe         String     @default("Konsumtif")
  pilar        Pilar      @relation(fields: [pilar_code], references: [code])
  proposals    Proposal[]

  @@index([pilar_code], map: "Program_pilar_code_fkey")
}

model Proposal {
  id                       String    @id @default(uuid())
  agenda_no                Int       @unique @default(autoincrement())
  tanggal_masuk            DateTime
  nama_instansi            String?
  pimpinan_organisasi      String?
  nama_pemohon             String
  nama_anak                String?
  nik                      String?
  tempat_lahir             String?
  tanggal_lahir            String?
  jenis_kelamin            String?
  alamat                   String?   @db.Text
  kelurahan                String?
  kecamatan                String?
  pekerjaan                String?
  jenis_permohonan         String?
  no_telpon                String?
  email                    String?
  jam_pengajuan            String?
  yang_mengajukan          String?
  has_memo                 Boolean   @default(false)
  memo_source              String?
  jenis_pengajuan          String    @default("")
  rekomendasi              String?
  keterangan               String?
  status                   String    @default("Pending")
  file_gdrive_id           String?
  file_gdrive_link         String?
  mustahik_id              String?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt
  isBeingSurveyed          Boolean?  @default(false)
  score                    Int?
  surveyorName             String?
  urgencyLevel             String?
  survey_data              Json?
  surveySubmittedAt        DateTime?
  catatanKepala            String?   @db.Text
  nominal                  Int?
  tipe_bantuan             String?
  alasan_perubahan_nominal String?   @db.Text
  catatanPimpinan          String?   @db.Text
  approval_kabag           Boolean?
  asnaf                    String?
  hasil_identifikasi       String?   @db.Text
  rekomendasi_kabag        String?
  rkat_activity_id         String?
  program                  Program?  @relation(fields: [jenis_permohonan], references: [code])
  mustahik                 Mustahik? @relation(fields: [mustahik_id], references: [id])

  @@index([jenis_permohonan], map: "Proposal_jenis_permohonan_fkey")
  @@index([mustahik_id], map: "Proposal_mustahik_id_fkey")
}

model Surat {
  id                  String    @id @default(uuid())
  agenda_no           Int       @unique @default(autoincrement())
  tanggal_masuk       DateTime
  nama_instansi       String?
  pimpinan_organisasi String?
  alamat              String?   @db.Text
  kelurahan           String?
  kecamatan           String?
  keperluan           String    @db.Text
  no_telpon           String?
  jam_pengajuan       String?
  yang_mengajukan     String?
  arsip               String?
  status              String    @default("Registrasi")
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  file_gdrive_id      String?
  file_gdrive_link    String?
  catatanKepala       String?   @db.Text
  catatanPimpinan     String?   @db.Text
  jam_acara           String?
  kategori            String?
  tanggal_acara       DateTime?
  assigned_staff      Json?
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SystemParameter {
  key         String   @id
  value       String   @db.Text
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
}

model ChartOfAccounts {
  coa_code       String           @id @db.VarChar(20)
  nama_akun      String           @db.VarChar(255)
  klasifikasi    String?          @db.VarChar(50)
  tipe_dana      String?          @db.VarChar(30)
  bankAccounts   BankAccount[]
  debitRules     CoaMappingRule[] @relation("DebitCoa")
  kreditRules    CoaMappingRule[] @relation("KreditCoa")
  journalEntries JournalEntry[]
}

model BankAccount {
  account_id            String               @id @default(uuid())
  nama_akun             String               @db.VarChar(100)
  tipe_kas              String               @db.VarChar(20)
  kelompok_dana         String               @db.VarChar(20)
  saldo                 Decimal              @default(0.00) @db.Decimal(15, 2)
  no_rekening           String?              @db.VarChar(50)
  kode_laci             String?              @db.VarChar(1)
  coa_code              String               @db.VarChar(20)
  coa                   ChartOfAccounts      @relation(fields: [coa_code], references: [coa_code])
  sourceMutations       CashMutation[]
  targetMutationDetails CashMutationDetail[]
  journalEntries        JournalEntry[]
  penerimaans           PenerimaanZis[]

  @@index([coa_code], map: "BankAccount_coa_code_fkey")
}

model CoaMappingRule {
  rule_id         String          @id @default(uuid())
  program_code    String          @db.VarChar(50)
  asnaf_id        String?         @db.VarChar(50)
  tipe_kas        String          @db.VarChar(20)
  sumber_dana_tag String          @db.VarChar(20)
  debit_coa_code  String          @db.VarChar(20)
  kredit_coa_code String          @db.VarChar(20)
  debitCoa        ChartOfAccounts @relation("DebitCoa", fields: [debit_coa_code], references: [coa_code])
  kreditCoa       ChartOfAccounts @relation("KreditCoa", fields: [kredit_coa_code], references: [coa_code])

  @@index([debit_coa_code], map: "CoaMappingRule_debit_coa_code_fkey")
  @@index([kredit_coa_code], map: "CoaMappingRule_kredit_coa_code_fkey")
}

model Realisasi {
  transaksi_id   String         @id @default(uuid())
  proposal_id    String?
  rkat_id        String?        @db.VarChar(100)
  tanggal        DateTime       @default(now())
  keterangan     String?        @db.Text
  nrm            String?        @db.VarChar(100)
  createdAt      DateTime       @default(now())
  journalEntries JournalEntry[]
}

model JournalEntry {
  entry_id     String          @id @default(uuid())
  transaksi_id String
  coa_code     String          @db.VarChar(20)
  debit        Decimal         @default(0.00) @db.Decimal(15, 2)
  kredit       Decimal         @default(0.00) @db.Decimal(15, 2)
  account_id   String?
  account      BankAccount?    @relation(fields: [account_id], references: [account_id])
  coa          ChartOfAccounts @relation(fields: [coa_code], references: [coa_code])
  realisasi    Realisasi       @relation(fields: [transaksi_id], references: [transaksi_id], onDelete: Cascade)

  @@index([account_id], map: "JournalEntry_account_id_fkey")
  @@index([coa_code], map: "JournalEntry_coa_code_fkey")
  @@index([transaksi_id], map: "JournalEntry_transaksi_id_fkey")
}

model CashMutation {
  mutation_id       String               @id @default(uuid())
  source_account_id String
  nominal_total     Decimal              @db.Decimal(15, 2)
  tanggal           DateTime             @default(now())
  keterangan        String?              @db.Text
  sourceAccount     BankAccount          @relation(fields: [source_account_id], references: [account_id])
  details           CashMutationDetail[]

  @@index([source_account_id], map: "CashMutation_source_account_id_fkey")
}

model CashMutationDetail {
  detail_id         String       @id @default(uuid())
  mutation_id       String
  target_account_id String
  nominal_alokasi   Decimal      @db.Decimal(15, 2)
  mutation          CashMutation @relation(fields: [mutation_id], references: [mutation_id], onDelete: Cascade)
  targetAccount     BankAccount  @relation(fields: [target_account_id], references: [account_id])

  @@index([mutation_id], map: "CashMutationDetail_mutation_id_fkey")
  @@index([target_account_id], map: "CashMutationDetail_target_account_id_fkey")
}

model RkatPengumpulan {
  id                String          @id @default(uuid())
  no                String
  kategori          String
  nama_program      String
  target_perorangan Int?
  target_lembaga    Int?
  nilai_anggaran    Decimal         @db.Decimal(15, 2)
  target_jan        Decimal?        @db.Decimal(15, 2)
  target_feb        Decimal?        @db.Decimal(15, 2)
  target_mar        Decimal?        @db.Decimal(15, 2)
  target_apr        Decimal?        @db.Decimal(15, 2)
  target_mei        Decimal?        @db.Decimal(15, 2)
  target_jun        Decimal?        @db.Decimal(15, 2)
  target_jul        Decimal?        @db.Decimal(15, 2)
  target_agt        Decimal?        @db.Decimal(15, 2)
  target_sep        Decimal?        @db.Decimal(15, 2)
  target_okt        Decimal?        @db.Decimal(15, 2)
  target_nov        Decimal?        @db.Decimal(15, 2)
  target_des        Decimal?        @db.Decimal(15, 2)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  coa_codes         String?         @db.Text
  penerimaans       PenerimaanZis[]
}

model PenerimaanZis {
  id                 String          @id @default(uuid())
  no_kuitansi        String          @unique
  muzakki_id         String
  rkat_id            String
  bank_account_id    String
  nominal            Decimal         @db.Decimal(15, 2)
  metode_pembayaran  String
  tanggal_pembayaran DateTime        @default(now())
  keterangan         String?         @db.Text
  status_simba       String          @default("PENDING")
  transaksi_id       String?
  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt
  bankAccount        BankAccount     @relation(fields: [bank_account_id], references: [account_id])
  muzakki            Muzakki         @relation(fields: [muzakki_id], references: [id])
  rkat               RkatPengumpulan @relation(fields: [rkat_id], references: [id])

  @@index([bank_account_id], map: "PenerimaanZis_bank_account_id_fkey")
  @@index([muzakki_id], map: "PenerimaanZis_muzakki_id_fkey")
  @@index([rkat_id], map: "PenerimaanZis_rkat_id_fkey")
}

model RkatOperasional {
  id             String   @id @default(uuid())
  no             String
  nama           String
  keterangan     String?  @db.Text
  coa_codes      String?  @db.Text
  volume         Int      @default(1)
  frekuensi      Int      @default(1)
  unit_cost      Decimal  @default(0.00) @db.Decimal(15, 2)
  nilai_anggaran Decimal  @default(0.00) @db.Decimal(15, 2)
  target_jan     Decimal? @db.Decimal(15, 2)
  target_feb     Decimal? @db.Decimal(15, 2)
  target_mar     Decimal? @db.Decimal(15, 2)
  target_apr     Decimal? @db.Decimal(15, 2)
  target_mei     Decimal? @db.Decimal(15, 2)
  target_jun     Decimal? @db.Decimal(15, 2)
  target_jul     Decimal? @db.Decimal(15, 2)
  target_agt     Decimal? @db.Decimal(15, 2)
  target_sep     Decimal? @db.Decimal(15, 2)
  target_okt     Decimal? @db.Decimal(15, 2)
  target_nov     Decimal? @db.Decimal(15, 2)
  target_des     Decimal? @db.Decimal(15, 2)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

enum Role {
  Super_Admin
  Ketua
  Wakil_Ketua_I
  Wakil_Ketua_II
  Wakil_Ketua_III
  Wakil_Ketua_IV
  Kabag_Administrasi
  Kabag_Pelaporan
  Kabag_Pengumpulan
  Kabag_Pendistribusian
  Kabag_Pendayagunaan
  Kepala_Pelaksana
  Staf_Administrasi
  Staf_Distribusi
  Staf_Keuangan
  Staf_Pengumpulan
  Staf_Pelaporan
  Relawan
  Relawan_Sementara
  Tim_Monev
}

enum KategoriUPZ {
  Masjid
  Yayasan_Lembaga
  Sekolah
  OPD
}
